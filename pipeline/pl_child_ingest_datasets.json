{
	"name": "pl_child_ingest_datasets",
	"properties": {
		"activities": [
			{
				"name": "ACT_GetRawETag",
				"description": "Fetching the Etag of each file to capture changes",
				"type": "WebActivity",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"method": "GET",
					"headers": {
						"User-Agent": " datamaieutic-adf"
					},
					"url": {
						"value": "@concat(pipeline().parameters.p_source_base_url,'/',pipeline().parameters.p_filename)",
						"type": "Expression"
					}
				}
			},
			{
				"name": "SET_CurrentETag",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "ACT_GetRawETag",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "",
					"value": ""
				}
			}
		],
		"parameters": {
			"p_filename": {
				"type": "string"
			},
			"p_category": {
				"type": "string"
			},
			"p_target_folder": {
				"type": "string"
			},
			"p_last_sha": {
				"type": "string"
			},
			"p_source_base_url": {
				"type": "string"
			},
			"p_github_api_base": {
				"type": "string"
			},
			"p_adls_base_path": {
				"type": "string"
			},
			"p_id": {
				"type": "string"
			},
			"p_log_path": {
				"type": "string"
			},
			"currentETag": {
				"type": "string"
			}
		},
		"folder": {
			"name": "pl_fifa_worldcup"
		},
		"annotations": []
	}
}